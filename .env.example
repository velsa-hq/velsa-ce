APP_NAME="Velsa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Safe mode — turns this instance into a Demo / Training / UAT environment:
# feature-complete but externally inert (e-signature + payment drivers forced
# to fakes; outbound mail redirected or suppressed). Server-enforced. The same
# image, just non-acting — used for the public demo and customer training.
VELSA_SAFE_MODE=false
VELSA_SAFE_MODE_LABEL=DEMO
# Redirect ALL outbound mail to one address; leave blank to suppress (log only).
VELSA_SAFE_MODE_MAIL_TO=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# In the container/deployed env set LOG_CHANNEL=stderr so the app log reaches
# the container log driver (CloudWatch/awslogs) -> centralized logging pipeline,
# consistent with Caddy + PHP-FPM (which already log to stderr). Local dev keeps
# the file channel above. The dedicated 'audit' channel always ships to stderr
# regardless; AUDIT_LOG_STREAM overrides its sink (php://temp under test).

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=velsa
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# DocuSign (set DOCUSIGN_ENABLED=true and fill remaining values once
# the JWT consent flow has been completed and DOCUSIGN_USER_ID +
# DOCUSIGN_ACCOUNT_ID are known).
DOCUSIGN_ENABLED=false
DOCUSIGN_BASE_URI="https://demo.docusign.net/restapi"
DOCUSIGN_OAUTH_BASE="https://account-d.docusign.com"
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_KEYPAIR_ID=
DOCUSIGN_PRIVATE_KEY_PATH=storage/app/keys/docusign-private.pem
DOCUSIGN_PUBLIC_KEY_PATH=storage/app/keys/docusign-public.pem
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=

# Single sign-on. Credentials live here so they never touch
# the repo. See docs/handbook/admin/sso-setup.md for the Entra portal
# walkthrough.
SSO_ENABLED=false
SSO_PROVISIONING=jit
SSO_DEFAULT_ROLE=venue_user
SSO_BOOTSTRAP_ADMIN_EMAILS=
SSO_MICROSOFT_ENABLED=false
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI="https://velsa.test/auth/sso/microsoft/callback"

# Global search (Laravel Scout + Meilisearch). Local Meilisearch
# typically runs at localhost:7700. Production should set a key for
# auth and a per-deployment prefix to avoid cross-tenant collisions.
SCOUT_DRIVER=meilisearch
SCOUT_PREFIX=velsa_
SCOUT_QUEUE=false
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=

# PDF Renderer (Gotenberg sidecar). Local dev: run gotenberg via
# docker-compose.dev-services.yml on port 3001. Production: point at
# the dedicated ECS service reachable only by app tasks.
PDF_RENDERER_URL=http://127.0.0.1:3001
PDF_RENDERER_TIMEOUT=30
PDF_RENDERER_RETRIES=0

# Training-video pipeline (training/pipeline/).
# ELEVENLABS_API_KEY: required to synthesize narration via TTS.
# TRAINING_VOICE_ID: optional override — set to a custom-cloned voice
#   ID once you've trained one in ElevenLabs. Falls back to the
#   public "Rachel" default in tts.ts when unset.
# DEMO_USER_EMAIL / DEMO_USER_PASSWORD: the Sentinel Bay demo super_admin
#   (admin@sentinelbay.ca.gov). Used as the seeded admin password
#   (SentinelBayUsersSeeder) and filled into the login form by the
#   Playwright pre-flight. Leave the password unset for local dev to
#   fall back to "password"; set a strong value on any deployed demo.
# DEMO_STAFF_PASSWORD: shared password for the ~14 seeded county staff.
#   Same local-dev fallback behavior.
ELEVENLABS_API_KEY=
TRAINING_VOICE_ID=
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=
DEMO_STAFF_PASSWORD=
