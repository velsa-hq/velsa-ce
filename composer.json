{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "palladium/velsa",
    "type": "project",
    "description": "Velsa: venue bookings, contracts, exhibitor orders, fund accounting, and operations for event-focused organizations.",
    "keywords": [
        "event-management",
        "venue-booking",
        "exhibitor-management",
        "fund-accounting",
        "laravel",
        "inertia",
        "react"
    ],
    "homepage": "https://velsa.io",
    "license": "proprietary",
    "authors": [
        {
            "name": "Palladium Innovations, LLC",
            "email": "sales@go-palladium.com",
            "homepage": "https://www.go-palladium.com"
        }
    ],
    "support": {
        "email": "sales@go-palladium.com",
        "source": "https://github.com/velsa-hq/velsa-ce"
    },
    "require": {
        "php": "^8.5",
        "docusign/esign-client": "^8.8",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/chisel": "^0.1.0",
        "laravel/fortify": "^1.37.2",
        "laravel/framework": "^13.7",
        "laravel/scout": "^11.2",
        "laravel/socialite": "^5.27",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1.14",
        "league/commonmark": "^2.8",
        "league/flysystem-aws-s3-v3": "^3.34",
        "meilisearch/meilisearch-php": "^1.16",
        "phpoffice/phpspreadsheet": "^5.7",
        "simshaun/recurr": "^6.0",
        "socialiteproviders/microsoft-azure": "^5.2",
        "spatie/laravel-medialibrary": "^11",
        "spatie/laravel-pdf": "^2.11",
        "spatie/laravel-permission": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/postmark-mailer": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "cyclonedx/cyclonedx-php-composer": "^6.2",
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9.3",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-drift": "^4.1",
        "pestphp/pest-plugin-laravel": "^4.1",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve --host=localhost\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "lint": [
            "pint --parallel"
        ],
        "lint:check": [
            "pint --parallel --test"
        ],
        "analyze": [
            "@php -d memory_limit=4G vendor/bin/phpstan analyse --no-progress"
        ],
        "analyze:baseline": [
            "@php -d memory_limit=4G vendor/bin/phpstan analyse --generate-baseline=phpstan-baseline.neon --allow-empty-baseline --no-progress"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "npm run lint:check",
            "npm run format:check",
            "npm run types:check",
            "@test"
        ],
        "test": [
            "@php artisan config:clear --no-ansi",
            "@lint:check",
            "@php artisan test"
        ],
        "test:local": [
            "Composer\\Config::disableProcessTimeout",
            "PCOV_DISABLED=1 php -d memory_limit=2G -d pcov.enabled=0 vendor/bin/pest --compact --no-coverage"
        ],
        "test:coverage": [
            "@php artisan config:clear --no-ansi",
            "@php -d xdebug.mode=coverage artisan test --coverage"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --no-ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --no-ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --no-ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --no-ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [],
            "installer": {
                "post-create-project": []
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "cyclonedx/cyclonedx-php-composer": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
